# Public Supabase configuration (required for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Set to "true" to log URL + anon key prefix in the browser console (debug 401 only)
# Remove or set to "false" for production
# NEXT_PUBLIC_DEBUG_SUPABASE=true

# Server-only (Vercel: set without NEXT_PUBLIC_ — never expose to browser)
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Application URL (used for redirects)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
